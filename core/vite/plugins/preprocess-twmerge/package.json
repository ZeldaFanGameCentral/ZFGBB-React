{
  "name": "@zfgc/vite-plugin-preprocess-twmerge",
  "description": "A vite plugin will preprocess `tailwind-merge` on JSX components className attributes, so that it does not have to be done at runtime.",
  "private": true,
  "version": "2025.10.0",
  "type": "module",
  "main": "./src/plugin.ts",
  "exports": {
    ".": {
      "import": "./src/plugin.ts",
      "types": "./src/plugin.ts"
    },
    "./ast/*": {
      "import": "./src/ast/*",
      "types": "./src/ast/*"
    },
    "./options": {
      "import": "./src/options.ts",
      "types": "./src/options.ts"
    },
    "./package.json": "./package.json",
    "./README.md": "./README.md"
  },
  "files": [
    "src",
    "src/ast",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "vite": "catalog:"
  },
  "devDependencies": {
    "oxc-parser": "^0.98.0",
    "oxc-transform": "^0.98.0",
    "tailwind-merge": "^3.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
