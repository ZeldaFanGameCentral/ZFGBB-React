{
  "name": "@zfgccp/vite-plugin-preprocess-twmerge",
  "private": true,
  "version": "2025.10.0",
  "type": "module",
  "main": "./src/plugin.ts",
  "exports": {
    ".": {
      "import": "./src/plugin.ts",
      "types": "./src/plugin.ts"
    },
    "./ast/*": {
      "import": "./src/ast/*",
      "types": "./src/ast/*"
    },
    "./options": {
      "import": "./src/options.ts",
      "types": "./src/options.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "src/ast",
    "package.json"
  ],
  "dependencies": {
    "vite": "catalog:"
  },
  "devDependencies": {
    "oxc-parser": "^0.95.0",
    "oxc-transform": "^0.95.0",
    "tailwind-merge": "^3.3.1"
  }
}
