      "updated": 1760840274390,
      "link": null,
      "locked": false,
      "text": "The GitHub repository has secrets per-environment \nthat contain the SSH Deployment Keys \nfor accessing the Linode server. These keys\nare not accessible by actions that invoke the workspace, due to\nsecurity reasons.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The GitHub repository has secrets per-environment \nthat contain the SSH Deployment Keys \nfor accessing the Linode server. These keys\nare not accessible by actions that invoke the workspace, due to\nsecurity reasons.",
      "autoResize": true,
      "lineHeight": 1.25
    },
